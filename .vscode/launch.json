{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Django: Run Server",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/manage.py",
            "args": [
                "runserver",
                "0.0.0.0:8000"
            ],
            "django": true,
            "justMyCode": true,
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/venv_linux/bin/python"
        },
        {
            "name": "Django: Run Server (No Reload)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/manage.py",
            "args": [
                "runserver",
                "--noreload",
                "0.0.0.0:8000"
            ],
            "django": true,
            "justMyCode": true,
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/venv_linux/bin/python"
        }
    ]
}
