{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Django Server",
            "type": "shell",
            "command": "${workspaceFolder}/venv_linux/bin/python",
            "args": [
                "manage.py",
                "runserver",
                "0.0.0.0:8000"
            ],
            "isBackground": true,
            "problemMatcher": {
                "pattern": {
                    "regexp": "^(.*):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
                    "file": 1,
                    "line": 2,
                    "column": 3,
                    "severity": 4,
                    "message": 5
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^Performing system checks",
                    "endsPattern": "^Quit the server with CONTROL-C\\.$"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Stop Django Server",
            "type": "shell",
            "command": "pkill",
            "args": [
                "-f",
                "python.*manage.py runserver"
            ]
        }
    ]
}
